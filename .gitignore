# Object files, which are produced by the compiler
*.o
*.obj

# Binary files, including executables, shared, and static libraries
*.exe
*.out
*.dll
*.so
*.dylib

# Backup files created by various editors
*.bak
*.swp
*.tmp

# Build directories commonly used
bin/
obj/
build/
debug/
release/

# Dependency directories
deps/

# Intermediate compilation files
*.d

# Build system generated files
Makefile
CMakeCache.txt
cmake_install.cmake
CMakeFiles/

# Build directories specifically for CMake
build*/

# User-specific files generated by the C++ tools
*.user
*.user.*
*.suo

# Editor directories and files for Visual Studio Code
.vscode/
*.code-workspace

# Static analysis and formatting tools
.clangd
.clang-tidy
.clang-format

# Log files and symbol databases
*.log
*.tlog
*.pdb

# Backup files and directories
*_backup/
